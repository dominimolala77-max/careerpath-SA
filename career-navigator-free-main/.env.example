# ═══════════════════════════════════════════════════════════════════════
# CareerPath SA — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# ┌─────────────────────────────────────────────────────────────────────┐
# │  NEVER commit the .env file to version control.                      │
# │  The .env.example is the only file that should be tracked by git.   │
# └─────────────────────────────────────────────────────────────────────┘
#
# Required variables marked with ⚠️  must be set for the app to start.
# ═══════════════════════════════════════════════════════════════════════

# ─── Supabase ─────────────────────────────────────────────────────────
# Get these from your Supabase project dashboard → Settings → API

# ⚠️ Full Supabase project URL (e.g. https://xxxx.supabase.co)
# SUPABASE_URL=YOUR_SUPABASE_URL

# ⚠️ Publishable (anon) key — safe for client-side use
# SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_ANON_KEY

# ⚠️ Service-role key — ❗ CLIENT-SIDE CODE MUST NEVER ACCESS THIS.
# This key bypasses Row-Level Security. Only use it in server-side code.
# Find it at: Supabase Dashboard → Settings → API → service_role key
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Project ID (human-readable slug)
# SUPABASE_PROJECT_ID=YOUR_PROJECT_ID

# ─── Yoco Payments ────────────────────────────────────────────────────
# Get these from your Yoco dashboard → Settings → API Keys

# ⚠️ Yoco secret key — ❗ NEVER expose this to the client
# YOCO_SECRET_KEY=YOUR_YOCO_SECRET_KEY

# ⚠️ Yoco public key — safe for client-side use
# YOCO_PUBLIC_KEY=YOUR_YOCO_PUBLIC_KEY

# ─── SMTP (Transactional Email — optional) ───────────────────────────
# Used for sending password resets, confirmations, etc.
# If not set, Supabase's built-in email service is used instead.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_FROM=CareerPath SA <noreply@careerpathsa.co.za>

# ─── Public (VITE_*) — Injected by Vite at build time ────────────────
# These are bundled into the client-side JS.

# VITE_SUPABASE_URL=YOUR_SUPABASE_URL
# VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_ANON_KEY
# VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_APP_URL=http://localhost:5173
VITE_APP_NAME=CareerPath SA

# ─── Node Environment ────────────────────────────────────────────────
# Set to "production" in your deployed environment.
NODE_ENV=development